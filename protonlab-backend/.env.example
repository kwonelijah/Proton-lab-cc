# ─── Stripe ───────────────────────────────────────────────────────────────────
# Found in Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Found in Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Google Sheets ────────────────────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Paste the entire contents of your Google Service Account JSON key file here (as a single line)
# Generated in Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Anthropic (Claude agent) ─────────────────────────────────────────────────
# Found at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
